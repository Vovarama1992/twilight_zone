TZ_DB_PATH=./data/twilight_zone.sqlite3
TZ_LOG_LEVEL=INFO

# "null", "openai", or "gemini". Null mode is deterministic and offline.
TZ_LLM_PROVIDER=null
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional generic JSON search endpoint. Leave empty for offline seed candidates.
# Response shape expected: {"results":[{"title":"...","url":"...","snippet":"...","source":"..."}]}
TZ_SEARCH_ENDPOINT=
TZ_SEARCH_API_KEY=

TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=
TZ_TELEGRAM_DRY_RUN=true

# Scheduler intervals.
TZ_ANALYSIS_INTERVAL_MINUTES=180
TZ_SEARCH_INTERVAL_MINUTES=90
TZ_DELIVERY_INTERVAL_MINUTES=20
TZ_SELF_REVIEW_INTERVAL_HOURS=72
