TZ_DB_PATH=/opt/twilight-zone/data/twilight_zone.sqlite3
TZ_LOG_LEVEL=INFO

TZ_LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Alternative:
# TZ_LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

TZ_SEARCH_PROVIDER=bing

# Optional. If set, it overrides TZ_SEARCH_PROVIDER.
TZ_SEARCH_ENDPOINT=
TZ_SEARCH_API_KEY=

TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=
TZ_TELEGRAM_DRY_RUN=false

TZ_ANALYSIS_INTERVAL_MINUTES=180
TZ_SEARCH_INTERVAL_MINUTES=90
TZ_DELIVERY_INTERVAL_MINUTES=20
TZ_SELF_REVIEW_INTERVAL_HOURS=72
